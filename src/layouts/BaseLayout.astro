---
import '../styles/global.css';
import { CATEGORIES } from '../categories';

interface Props {
  title: string;
  description: string;
  /** 文章頁傳入，用於 og:type、BlogPosting schema 與 og:image 分類配色 */
  article?: { pubDate: Date; category?: keyof typeof CATEGORIES };
  /** 分類頁傳入，決定 og:image 用哪個分類的分享圖 */
  ogCategory?: keyof typeof CATEGORIES;
  /** 首頁才傳 true，加上 WebSite schema（沒有站內搜尋，所以不加 potentialAction） */
  isHome?: boolean;
}

const { title, description, article, ogCategory, isHome } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const siteName = '企鵝媽媽的行李箱 Penguin Mama';
const fullTitle = title === siteName ? title : `${title}｜${siteName}`;
const ogImageKey = article?.category ?? ogCategory ?? 'default';
const ogImage = new URL(`/og/${ogImageKey}.png`, Astro.site);

const publisher = {
  '@type': 'Organization',
  name: siteName,
  logo: { '@type': 'ImageObject', url: new URL('/penguin-logo-red.png', Astro.site).toString() },
};
const author = {
  '@type': 'Person',
  name: '企鵝媽媽',
  url: new URL('/about/', Astro.site).toString(),
};

const jsonLdList = article
  ? [
      {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        datePublished: article.pubDate.toISOString(),
        dateModified: article.pubDate.toISOString(),
        author,
        publisher,
        mainEntityOfPage: canonical.toString(),
      },
    ]
  : [
      {
        '@context': 'https://schema.org',
        '@type': 'Blog',
        name: siteName,
        description,
        url: canonical.toString(),
      },
    ];

if (isHome) {
  jsonLdList.push({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: siteName,
    url: Astro.site?.toString(),
  });
}
---
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />
  <link rel="icon" href="/favicon.png" type="image/png" />

  <!-- Open Graph / 社群分享 -->
  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="zh_TW" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />

  {jsonLdList.map((jsonLd) => (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  ))}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <a href="#main" class="skip-link">跳到主要內容</a>
  <header>
    <nav class="nav">
      <a class="brand" href="/" aria-label="企鵝媽媽的行李箱首頁">
        <img src="/penguin-logo-red.png" alt="" aria-hidden="true" style="width:42px;height:42px;object-fit:contain;mix-blend-mode:multiply;background:transparent;flex-shrink:0" />
        <span>企鵝媽媽的行李箱</span>
      </a>
      <button class="menu-btn" aria-label="開啟選單" aria-expanded="false" aria-controls="navLinks" id="menuBtn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
      <div class="nav-links" id="navLinks">
        <a href="/category/parenting/">企鵝寶寶副本</a>
        <a href="/category/working/">副本裡的大人</a>
        <a href="/category/travel/">親子行李箱</a>
        <a href="/category/solo/">一個人的行李箱</a>
        <a href="/about/">關於我</a>
      </div>
    </nav>
  </header>

  <main id="main">
    <slot />
  </main>

  <footer>
    <b>企鵝媽媽的行李箱 Penguin Mama</b><br />
    副本人生進行中 · 暫無業配，請安心服用

    <nav class="footer-links" aria-label="頁尾導覽">
      <a href="/category/parenting/">企鵝寶寶副本</a>
      <a href="/category/working/">副本裡的大人</a>
      <a href="/category/travel/">親子行李箱</a>
      <a href="/category/solo/">一個人的行李箱</a>
      <a href="/about/">關於我</a>
      <a href="mailto:penguinmama.blog@gmail.com">聯絡我</a>
      <a href="/rss.xml">RSS</a>
    </nav>

    © {new Date().getFullYear()} 企鵝媽媽的行李箱 · 保留所有權利 · 未經同意請勿轉載
  </footer>

  <script>
    const btn = document.getElementById('menuBtn');
    const links = document.getElementById('navLinks');
    btn?.addEventListener('click', () => {
      const open = links!.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? '關閉選單' : '開啟選單');
    });
    links?.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        links.classList.remove('open');
        btn?.setAttribute('aria-expanded', 'false');
        btn?.setAttribute('aria-label', '開啟選單');
      })
    );
  </script>
</body>
</html>
