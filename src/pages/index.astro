---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, type CategoryKey } from '../categories';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = posts[0];
const byCategory = (key: CategoryKey) =>
  posts.filter((p) => p.data.category === key).slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long' });
---
<BaseLayout
  title="企鵝媽媽 Penguin Mama"
  description="企鵝媽媽的個人部落格：親子生活、職業父母的日常、帶著孩子旅行的心得筆記。"
>
  <!-- Hero -->
  <section class="hero">
    <div>
      <span class="eyebrow">Penguin Mama · 企鵝媽媽</span>
      <h1>一手牽著孩子，<br />一手拖著<span class="gold">行李箱</span>的日常</h1>
      <p>我是企鵝媽媽——白天是銀行裡的職業媽媽，下班後是陪玩夥伴，假期則是帶著兒子到處走的旅伴。這裡記錄親子生活、職場父母的生存之道，還有一篇篇邊走邊寫的旅遊手記。</p>
      <a class="cta" href="#featured">開始閱讀</a>
    </div>
    <div class="hero-art" aria-hidden="true">
      <img src="/penguin-logo-red.png" alt="" style="width:min(320px,80%);height:auto;filter:drop-shadow(0 8px 24px rgba(154,59,59,.15))" />
    </div>
  </section>

  <!-- 分類：行李吊牌 -->
  <section class="tags-strip">
    <h2>行李吊牌｜三個主題</h2>
    <div class="tags">
      {Object.entries(CATEGORIES).map(([key, c]) => (
        <a class="tag" href={`/category/${key}/`}>
          <b>{c.name}</b><span>{c.blurb}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- 精選 -->
  <section class="section" id="featured">
    {featured && (
      <article class="featured">
        <div>
          <div class="cat">{CATEGORIES[featured.data.category].name} · 最新文章</div>
          <h3>{featured.data.title}</h3>
          <p>{featured.data.description}</p>
        </div>
        <a class="read" href={`/blog/${featured.id}/`}>閱讀全文</a>
      </article>
    )}

    {Object.entries(CATEGORIES).map(([key, c], i) => (
      <>
        {i === 1 && (
          <div class="footprints" aria-hidden="true">
            <span>🐾</span><span>🐾</span><span>🐾</span><span>🐾</span><span>🐾</span>
          </div>
        )}
        <div class="section-head" id={key}>
          <h2>{c.name}</h2>
          <a href={`/category/${key}/`}>更多文章 →</a>
        </div>
        <div class="grid" style="margin-bottom:56px">
          {byCategory(key as CategoryKey).map((post) => (
            <a class="card" href={`/blog/${post.id}/`}>
              <span class="cat">{c.name}</span>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
            </a>
          ))}
        </div>
      </>
    ))}
  </section>

  <!-- 關於我 -->
  <section class="about" id="about">
    <div class="about-avatar" aria-hidden="true">
      <img src="/penguin-logo-black.png" alt="" style="width:110px;height:110px;object-fit:contain" />
    </div>
    <div>
      <h2>關於企鵝媽媽</h2>
      <p>企鵝爸爸孵蛋、企鵝媽媽遠行覓食——這個名字提醒我，媽媽也可以是那個帶著全家往前走的人。我在金融業工作，是一個小男孩的媽媽，也是蒙特梭利教育的實踐者。這個部落格寫給和我一樣、在工作與家庭之間認真生活的你。</p>
    </div>
  </section>

  <!-- 訂閱 -->
  <section class="subscribe">
    <h2>訂閱企鵝媽媽的信</h2>
    <p>每月一封，整理最新的親子旅行筆記與職場爸媽心得。</p>
    <div class="sub-row">
      <input type="email" placeholder="你的 Email" aria-label="Email" id="subEmail" />
      <button id="subBtn">訂閱</button>
    </div>
    <p class="sub-note" id="subNote">不會寄垃圾信，隨時可以取消。</p>
  </section>

  <script>
    document.getElementById('subBtn')?.addEventListener('click', () => {
      const email = (document.getElementById('subEmail') as HTMLInputElement).value.trim();
      const note = document.getElementById('subNote')!;
      note.textContent = email.includes('@')
        ? '已收到！歡迎加入企鵝家族 🐧'
        : '請輸入有效的 Email 再按訂閱。';
    });
  </script>
</BaseLayout>
